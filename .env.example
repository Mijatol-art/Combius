# ==================== DISCORD TOKENS ====================
DISCORD_TOKENS=token1_here,token2_here,token3_here

# ==================== CHANNEL CONFIG ====================
CHANNEL_IDS=123456789012345678,234567890123456789

# ==================== TIMING ====================
MIN_DELAY=20
MAX_DELAY=40

# ==================== SELLALL ====================
SELLALL_INTERVAL=100
SELLALL_COOLDOWN=600

# ==================== GEMS ====================
GEM_ENABLED=true
GEM_IDS=51,52,53,56
AUTO_SCAN_GEMS=true

# ==================== INVENTORY MANAGEMENT ====================
# Scan inventory every N command cycles (0 = disabled)
INVENTORY_CHECK_INTERVAL=20
# Auto-open ALL lootboxes when detected: owo lb all
AUTO_OPEN_LOOTBOXES=true
# Auto-open ALL weapon crates when detected: owo wc all
AUTO_OPEN_CRATES=true

# ==================== DAILY ====================
AUTO_CLAIM=true

# ==================== VERIFICATION ====================
VERIFY_SOUND=true

# ==================== CAPTCHA ====================
CAPTCHA_SERVICE=manual
CAPMONSTER_API_KEY=
TWOCAPTCHA_API_KEY=

# ==================== PER-TOKEN GEMS ====================
# Format: TOKEN_GEMS_<token_prefix>=id1,id2,id3
# Example for token starting with MTIzNDU:
# TOKEN_GEMS_MTIzNDU=56,70,77
# Leave empty to use GEM_IDS for all